<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DanielOS Terminal"
        android:textStyle="bold"
        android:textSize="18sp"
        android:paddingBottom="4dp" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="mode=local-fallback | shell=starting"
        android:textSize="11sp"
        android:textColor="#5C6BC0"
        android:paddingBottom="6dp" />

    <ScrollView
        android:id="@+id/outputScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:background="#101316"
        android:padding="10dp"
        android:scrollbarStyle="outsideInset">

        <TextView
            android:id="@+id/outputText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#C9F9D4"
            android:textSize="13sp"
            android:typeface="monospace"
            android:text="DanielOS" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <EditText
            android:id="@+id/inputCommand"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="명령어 입력 (예: ls -al)"
            android:singleLine="true"
            android:imeOptions="actionGo" />

        <Button
            android:id="@+id/runButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="실행"
            android:textSize="12sp"
            android:layout_marginStart="8dp"
            android:minWidth="72dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4">

            <Button
                android:id="@+id/restartButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="재시작"
                android:textSize="11sp"
                android:maxLines="1" />

            <Button
                android:id="@+id/interruptButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="중단"
                android:textSize="11sp"
                android:layout_marginStart="6dp"
                android:maxLines="1" />

            <Button
                android:id="@+id/clearButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="지우기"
                android:textSize="11sp"
                android:layout_marginStart="6dp"
                android:maxLines="1" />

            <Button
                android:id="@+id/helpButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="도움말"
                android:textSize="11sp"
                android:layout_marginStart="6dp"
                android:maxLines="1" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:weightSum="4">

            <Button
                android:id="@+id/prevHistoryButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="이전"
                android:textSize="11sp"
                android:maxLines="1" />

            <Button
                android:id="@+id/nextHistoryButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="다음"
                android:textSize="11sp"
                android:layout_marginStart="6dp"
                android:maxLines="1" />

            <Button
                android:id="@+id/exportLogButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="저장"
                android:textSize="11sp"
                android:layout_marginStart="6dp"
                android:maxLines="1" />

            <Button
                android:id="@+id/copyLogButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="복사"
                android:textSize="11sp"
                android:layout_marginStart="6dp"
                android:maxLines="1" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/keyEscButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ESC"
                    android:textSize="10sp" />

                <Button
                    android:id="@+id/keyTabButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="TAB"
                    android:textSize="10sp" />

                <Button
                    android:id="@+id/keySlashButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="/"
                    android:textSize="10sp" />

                <Button
                    android:id="@+id/keyDashButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="-"
                    android:textSize="10sp" />

                <Button
                    android:id="@+id/keyPipeButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="|"
                    android:textSize="10sp" />

                <Button
                    android:id="@+id/keyTildeButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="~"
                    android:textSize="10sp" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

</LinearLayout>
