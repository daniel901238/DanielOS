<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="8dp">

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="mode=direct-terminal | shell=starting"
        android:textSize="10sp"
        android:textColor="#9E9E9E"
        android:typeface="monospace"
        android:paddingBottom="4dp" />

    <EditText
        android:id="@+id/terminalEdit"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#000000"
        android:textColor="#FFFFFF"
        android:textColorHint="#BDBDBD"
        android:textSize="14sp"
        android:typeface="monospace"
        android:lineSpacingExtra="1dp"
        android:gravity="top|start"
        android:inputType="textMultiLine|textNoSuggestions"
        android:imeOptions="flagNoExtractUi"
        android:overScrollMode="ifContentScrolls"
        android:padding="6dp"
        android:scrollbars="vertical" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp"
        android:weightSum="4">

        <Button
            android:id="@+id/restartButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="재시작"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:background="#000000" />

        <Button
            android:id="@+id/interruptButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="중단"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:layout_marginStart="4dp"
            android:background="#000000" />

        <Button
            android:id="@+id/clearButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="지우기"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:layout_marginStart="4dp"
            android:background="#000000" />

        <Button
            android:id="@+id/helpButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="도움말"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:layout_marginStart="4dp"
            android:background="#000000" />
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/keyEscButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ESC"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:background="#000000" />

                <Button
                    android:id="@+id/keySlashButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="/"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:background="#000000" />

                <Button
                    android:id="@+id/keyDashButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="-"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:background="#000000" />

                <Button
                    android:id="@+id/keyHomeButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="HOME"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:background="#000000" />

                <Button
                    android:id="@+id/keyUpButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="↑"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:background="#000000" />

                <Button
                    android:id="@+id/keyEndButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="END"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:background="#000000" />

                <Button
                    android:id="@+id/keyPgUpButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="PGUP"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:background="#000000" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp">

                <Button
                    android:id="@+id/keyTabButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TAB"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:background="#000000" />

                <Button
                    android:id="@+id/keyCtrlButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="CTRL"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:background="#000000" />

                <Button
                    android:id="@+id/keyAltButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="ALT"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:background="#000000" />

                <Button
                    android:id="@+id/keyLeftButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="←"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:background="#000000" />

                <Button
                    android:id="@+id/keyDownButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="↓"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:background="#000000" />

                <Button
                    android:id="@+id/keyRightButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="→"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:background="#000000" />

                <Button
                    android:id="@+id/keyPgDnButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="PGDN"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:background="#000000" />

                <Button
                    android:id="@+id/keyPipeButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="|"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:background="#000000" />

                <Button
                    android:id="@+id/keyTildeButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="~"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:background="#000000" />
            </LinearLayout>
        </LinearLayout>
    </HorizontalScrollView>
</LinearLayout>
